{
  "name": "worker-name",
  "compatibility_date": "2025-06-17",
  "main": "index.ts",
  "compatibility_flags": ["nodejs_compat"],
  "queues": {
    "producers": [
      {
        "queue": "test-queue",
        "binding": "MY_QUEUE",
      },
    ],
    "consumers": [
      {
        "queue": "test-queue",
        "max_batch_size": 10,
        "max_batch_timeout": 1,
        "max_retries": 0,
      },
    ],
  },
}
