    "@sentry-internal/test-utils": "link:../../../test-utils",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
