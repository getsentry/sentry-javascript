{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-mcp-agent",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-21",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_AGENT",
        "class_name": "MyMCPAgent",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MyMCPAgent"],
    },
  ],
}
