{
  "name": "node-express-send-to-sentry-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "playwright test",
    "clean": "npx rimraf node_modules pnpm-lock.yaml",
    "test:build": "pnpm install && pnpm build",
    "test:assert": "pnpm test"
  },
  "dependencies": {
    "@sentry/node": "file:../../packed/sentry-node-packed.tgz",
    "@types/express": "4.17.17",
    "@types/node": "^18.19.1",
    "express": "^4.21.2",
    "typescript": "~5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "~1.56.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "sentryTest": {
    "optional": true,
    "optionalVariants": [
      {
        "build-command": "env E2E_USE_SENTRY_TRACE_PROVIDER=1 pnpm test:build",
        "assert-command": "env E2E_USE_SENTRY_TRACE_PROVIDER=1 pnpm test:assert",
        "label": "node-express-send-to-sentry (sentry-trace-provider)"
      }
    ]
  }
}
