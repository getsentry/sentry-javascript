{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@sentry-internal/typescript/tsconfig.json",
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true
  }
}
