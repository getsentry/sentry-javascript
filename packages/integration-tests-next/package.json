{
  "name": "@sentry-internal/integration-tests-next",
  "version": "5.1.1",
  "license": "MIT",
  "private": true,
  "scripts": {
    "test": "node setup.mjs && vitest run --pool threads",
    "lint": "eslint .",
    "check:types": "tsc --project ./tsconfig.json --noEmit",
