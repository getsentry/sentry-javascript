{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.base.json"],
  "env": {
    "browser": true
  },
  "overrides": [
    {
      "files": ["src/**/*.{js,ts,d.ts}"],
      "rules": {
        "import/no-unresolved": "off",
        "no-restricted-globals": "off"
      }
    }
  ]
}
